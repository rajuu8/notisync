<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E293B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="#1E3A5F"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔔"
                            android:textSize="22sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NotiSync"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9"/>
                        <TextView
                            android:id="@+id/tv_connected"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Code: ----"
                            android:textSize="11sp"
                            android:textColor="#3B82F6"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#2563EB"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#0F172A"
                    android:padding="10dp">
                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_green"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Connecting..."
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Audio Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E293B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎙️ One Way Audio"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_audio_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio ready — Phone 2 se request aane do"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btn_allow_audio"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Allow Audio"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#16A34A"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Permission Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E293B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notification Permission"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_perm_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Check ho raha hai..."
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btn_give_permission"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Permission Do"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2563EB"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_clear_all"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Clear All"
                android:textColor="#EF4444"
                android:backgroundTint="#1E293B"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <Button
                android:id="@+id/btn_disconnect"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Disconnect"
                android:textColor="#94A3B8"
                android:backgroundTint="#1E293B"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
